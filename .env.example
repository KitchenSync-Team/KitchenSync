# ============================================================
# KitchenSync — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# Contact the team for shared Supabase, S3, and API credentials.
# ============================================================


# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # same value as anon key
SUPABASE_SERVICE_ROLE_KEY=              # server-only — never expose to the browser


# ------------------------------------------------------------
# Recipe APIs (Spoonacular)
# ------------------------------------------------------------
SPOONACULAR_RAPIDAPI_KEY=              # preferred — get a key at rapidapi.com
SPOONACULAR_RAPIDAPI_HOST=spoonacular-recipe-food-nutrition-v1.p.rapidapi.com
SPOONACULAR_API_KEY=                   # fallback if not using RapidAPI


# ------------------------------------------------------------
# OpenAI (recipe standardization)
# ------------------------------------------------------------
OPENAI_API_KEY=


# ------------------------------------------------------------
# Avatar Storage (S3-compatible)
# Only required if testing avatar uploads locally.
# ------------------------------------------------------------
S3_AVATARS_REGION=
S3_AVATARS_ENDPOINT=
S3_AVATARS_ACCESS_KEY=
S3_AVATARS_SECRET_KEY=
S3_AVATARS_BUCKET=
